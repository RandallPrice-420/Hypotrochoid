<Window x:Class="WpfApplication1.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Window1"
        Height="300"
        Width="300"
        WindowStyle="None">
	<Canvas Background="LightBlue">
		<Canvas Canvas.Left="20"
		        Canvas.Top="20">
			<Canvas Canvas.Left="10"
			        Canvas.Top="10">
				<Canvas.RenderTransform>
					<RotateTransform Angle="-40"
					                 CenterX="100"
					                 CenterY="100"/>
				</Canvas.RenderTransform>
				<Ellipse Width="200"
				         Height="200"
				         Stroke="Black"
				         Fill="Yellow"/>
				<Line X1="100"
				      Y1="100"
				      X2="200"
				      Y2="100"
				      Stroke="Black"/>
				<Label Content="A"
				       Canvas.Left="140"
				       Canvas.Top="70"
				       FontWeight="Bold"
				       FontFamily="Arial"
				       FontSize="16"/>
			</Canvas>
			<Canvas Canvas.Left="10"
			        Canvas.Top="10"
			        Width="75"
			        Height="75">
				<Canvas.RenderTransform>
					<TranslateTransform X="130"
					                    Y="65"/>
				</Canvas.RenderTransform>
				<Ellipse Width="70"
				         Height="70"
				         Stroke="Black"
				         Fill="LightGreen"/>
				<Line X1="35"
				      Y1="35"
				      X2="70"
				      Y2="35"
				      Stroke="Black"/>
				<Label Content="B"
				       Canvas.Left="40"
				       Canvas.Top="10"
				       FontWeight="Bold"
				       FontFamily="Arial"
				       FontSize="16"/>
				<Canvas>
					<Canvas.RenderTransform>
						<RotateTransform Angle="30"
						                 CenterX="35"
						                 CenterY="35"/>
					</Canvas.RenderTransform>
					<Line X1="35"
					      Y1="35"
					      X2="100"
					      Y2="35"
					      Stroke="Black"/>
					<Ellipse Canvas.Left="95"
					         Canvas.Top="30"
					         Width="10"
					         Height="10"
					         Fill="Red"/>
					<Label Content="C"
					       Canvas.Left="65"
					       Canvas.Top="10"
					       FontWeight="Bold"
					       FontFamily="Arial"
					       FontSize="16"/>
				</Canvas>
			</Canvas>
		</Canvas>
	</Canvas>
</Window>
